{
  "name": "monkdb-workbench",
  "version": "1.1.0",
  "description": "MonkDB Workbench - Professional desktop application for MonkDB database management",
  "author": "MonkDB Team",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:standalone": "TAURI_BUILD=true next build",
    "start": "next start",
    "lint": "eslint",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build:standalone && tauri build",
    "tauri:build:mac": "npm run build:standalone && tauri build --target universal-apple-darwin",
    "tauri:build:win": "npm run build:standalone && tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:linux": "npm run build:standalone && tauri build --target x86_64-unknown-linux-gnu",
    "tauri:icon": "tauri icon public/icon.png"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "@types/validator": "^13.15.10",
    "date-fns": "^3.0.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.5",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.555.0",
    "monaco-editor": "^0.52.2",
    "mongodb": "^7.0.0",
    "next": "16.0.6",
    "react": "19.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "19.2.0",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "validator": "^13.15.26",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.9.6",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
