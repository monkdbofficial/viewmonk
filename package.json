{
  "name": "monkdb-workbench",
  "version": "1.1.0",
  "description": "MonkDB Workbench - Professional desktop application for MonkDB database management",
  "author": "MonkDB Team",
  "private": true,
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:standalone": "TAURI_BUILD=true next build",
    "start": "next start",
    "lint": "eslint",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build:standalone && tauri build",
    "tauri:build:mac": "npm run build:standalone && tauri build --target universal-apple-darwin --bundles app",
    "tauri:build:mac:dmg": "npm run tauri:build:mac && ./scripts/create-dmg.sh",
    "tauri:build:win": "npm run build:standalone && tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:linux": "npm run build:standalone && tauri build --target x86_64-unknown-linux-gnu",
    "tauri:icon": "tauri icon public/icon.png"
  },
  "dependencies": {
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@mapbox/mapbox-gl-geocoder": "^5.1.2",
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "@turf/turf": "^7.3.2",
    "@types/mapbox-gl": "^3.4.1",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.15.10",
    "@xenova/transformers": "^2.17.2",
    "date-fns": "^3.0.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.5",
    "elkjs": "^0.11.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.555.0",
    "mammoth": "^1.11.0",
    "mapbox-gl": "^3.18.0",
    "marked": "^17.0.1",
    "monaco-editor": "^0.52.2",
    "mongodb": "^7.0.0",
    "next": "^16.1.1",
    "papaparse": "^5.5.3",
    "pg": "^8.18.0",
    "pptxgenjs": "^4.0.1",
    "react": "19.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "19.2.0",
    "react-leaflet": "^4.2.1",
    "react-map-gl": "^8.1.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^13.0.0",
    "validator": "^13.15.26",
    "xlsx": "^0.18.5",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.9.6",
    "@types/leaflet": "^1.9.21",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@types/mapbox__mapbox-gl-geocoder": "^5.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
