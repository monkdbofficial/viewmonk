<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow network access for database connections -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Allow network server for local development -->
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- Allow file access for logs, audit trails, and configuration -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Allow access to user home directory for app data -->
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>

  <!-- Required for auto-updates -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Allow keychain access for credential storage -->
  <key>keychain-access-groups</key>
  <array>
    <string>$(AppIdentifierPrefix)com.monkdb.workbench</string>
  </array>

  <!-- Disable library validation for native dependencies -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Allow unsigned executable memory for JIT compilation -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Hardened runtime -->
  <key>com.apple.security.app-sandbox</key>
  <false/>
</dict>
</plist>
